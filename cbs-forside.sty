% Ændre størrelsen og formatet for \chapter
\titleformat{\chapter}[hang]{\normalfont\LARGE\bfseries}{\thechapter}{0.5pc}{}

% Ændre størrelsen og formatet for \section
\titleformat{\section}
  {\rmfamily\Large\bfseries\raggedright}{\thesection}{1em}{}

% Ændre størrelsen og formatet for \subsection
\titleformat{\subsection}
  {\rmfamily\large\bfseries}{\thesubsection}{1em}{}

% Ændre størrelsen og formatet for \subsubsection
\titleformat{\subsubsection}
  {\rmfamily\scshape\bfseries\normalsize}{\thesubsubsection}{1em}{}


\titlespacing*{\chapter}{0cm}{-0.5cm}{0.3cm}
\titlespacing*{\section}{0cm}{0.3cm}{0.3cm}
\titlespacing*{\subsection}{0cm}{0.3cm}{0.3cm}


